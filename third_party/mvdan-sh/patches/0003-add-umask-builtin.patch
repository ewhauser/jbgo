+func runnerUmask(r *Runner) uint32 {
+	if r == nil {
+		return 0o022
+	}
+	raw := strings.TrimSpace(r.envGet("GBASH_UMASK"))
+	if raw == "" {
+		return 0o022
+	}
+	value, err := strconv.ParseUint(raw, 8, 32)
+	if err != nil || value > 0o777 {
+		return 0o022
+	}
+	return uint32(value)
+}
