#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --describe)
    echo "show usage and discovered plugins"
    exit 0
    ;;
esac

source "${HARNESS_CWD:-${PWD}}/.harness/lib/runtime.sh"

discover_providers() {
  local saved_provider="${HARNESS_PROVIDER}"
  HARNESS_PROVIDER=""
  harness_refresh_sources
  HARNESS_PROVIDER="${saved_provider}"

  declare -A provider_map=()
  local src f
  for src in "${_GBASH_HARNESS_SOURCES[@]}"; do
    [[ -d "${src}/providers" ]] || continue
    for f in "${src}/providers"/*; do
      [[ -x "${f}" ]] && provider_map["$(basename "${f}")"]="${f}"
    done
  done

  local name
  for name in "${!provider_map[@]}"; do
    echo "${name} ${provider_map[$name]}"
  done
}

harness_refresh_sources

cat <<'EOF'
harness — minimal agent loop, maximum extensibility

usage:
  ./bin/harness "do something"  one-shot: run agent with a message
  ./bin/harness                 interactive REPL (new session)
  ./bin/harness <session-id>    resume a session
  ./bin/harness agent [args...] explicit (same as above)
  ./bin/harness session <sub> [args]
  ./bin/harness tools
  ./bin/harness hooks [stage]
  ./bin/harness version
  ./bin/harness help
EOF

echo ""
echo "environment:"
cat <<'EOF'
  HARNESS_PROVIDER         provider (auto: first with credentials)
  HARNESS_MODEL            model (auto from provider --defaults)
  HARNESS_MAX_TURNS        max agent loop iterations (100)
  HARNESS_TOOL_TIMEOUT     per-tool timeout in seconds
EOF

echo ""
echo "providers (discovered):"
while read -r name path; do
  [[ -z "${name}" ]] && continue
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  printf '  %-20s %s\n' "${name}" "${desc}"
done < <(discover_providers)

echo ""
echo "tools (discovered):"
declare -A tool_map=()
for src in "${_GBASH_HARNESS_SOURCES[@]}"; do
  [[ -d "${src}/tools" ]] || continue
  for f in "${src}/tools"/*; do
    [[ -x "${f}" ]] || continue
    tool_map["$(basename "${f}")"]="${f}"
  done
done
for name in $(printf '%s\n' "${!tool_map[@]}" | sort); do
  path="${tool_map[$name]}"
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  printf '  %-20s %s\n' "${name}" "${desc}"
done

echo ""
echo "commands:"
for name in agent auth help hooks session tools version; do
  path="$(harness_find_command "${name}")"
  [[ -n "${path}" ]] || continue
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  printf '  %-20s %s\n' "${name}" "${desc}"
done
