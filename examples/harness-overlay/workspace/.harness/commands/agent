#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --describe)
    echo "run the agent (interactive or one-shot)"
    exit 0
    ;;
esac

source "${HARNESS_CWD:-${PWD}}/.harness/lib/runtime.sh"

resolve_provider() {
  harness_refresh_sources

  if [[ -z "${HARNESS_PROVIDER}" ]]; then
    local src f name
    for src in "${_GBASH_HARNESS_SOURCES[@]}"; do
      [[ -d "${src}/providers" ]] || continue
      for f in "${src}/providers"/*; do
        if [[ -x "${f}" ]]; then
          name="$(basename "${f}")"
          if "${f}" --ready 2>/dev/null; then
            HARNESS_PROVIDER="${name}"
            break 2
          fi
        elif [[ "${f}" == *.conf ]]; then
          name="$(basename "${f}" .conf)"
          local auth_env
          auth_env="$(grep '^auth_env=' "${f}" | head -1 | cut -d= -f2-)"
          if [[ -n "${auth_env}" ]]; then
            local auth_value
            auth_value="${!auth_env:-}"
            if [[ -n "${auth_value}" ]]; then
              HARNESS_PROVIDER="${name}"
              break 2
            fi
          fi
          local cache="${HARNESS_HOME}/.auth-cache.json"
          if [[ -f "${cache}" ]] && jq -e ".\"${name}\" | length > 0" "${cache}" &>/dev/null; then
            HARNESS_PROVIDER="${name}"
            break 2
          fi
        fi
      done
    done
  fi

  [[ -z "${HARNESS_PROVIDER}" ]] && return 0

  local conf_file=""
  local src
  for src in "${_GBASH_HARNESS_SOURCES[@]}"; do
    if [[ -f "${src}/providers/${HARNESS_PROVIDER}.conf" ]]; then
      conf_file="${src}/providers/${HARNESS_PROVIDER}.conf"
    fi
  done

  if [[ -n "${conf_file}" ]]; then
    local model_val
    model_val="$(grep '^model=' "${conf_file}" | head -1 | cut -d= -f2-)"
    [[ -n "${model_val}" && -z "${HARNESS_MODEL}" ]] && HARNESS_MODEL="${model_val}"
    return 0
  fi

  local provider_path=""
  for src in "${_GBASH_HARNESS_SOURCES[@]}"; do
    if [[ -x "${src}/providers/${HARNESS_PROVIDER}" ]]; then
      provider_path="${src}/providers/${HARNESS_PROVIDER}"
    fi
  done
  [[ -z "${provider_path}" ]] && return 0

  local key val
  while IFS='=' read -r key val; do
    [[ -z "${key}" ]] && continue
    case "${key}" in
      model)
        [[ -z "${HARNESS_MODEL}" ]] && HARNESS_MODEL="${val}"
        ;;
    esac
  done < <("${provider_path}" --defaults 2>/dev/null || true)
}

resolve_provider

session_dir=""
message=""
mode=""

if [[ -n "${1:-}" && -d "${HARNESS_SESSIONS}/${1}" ]]; then
  session_dir="${HARNESS_SESSIONS}/${1}"
  mode="repl"
elif (( $# > 0 )); then
  message="$*"
  mode="oneshot"
elif [[ ! -t 0 ]]; then
  message="$(cat)"
  mode="oneshot"
else
  mode="repl"
fi

if [[ -z "${session_dir}" ]]; then
  session_dir="$(harness_new_session)"
  echo "session: $(basename "${session_dir}")" >&2
fi

if [[ "${mode}" == "oneshot" ]]; then
  harness_save_user_message "${session_dir}" "${message}"
  harness_agent_loop "${session_dir}"
  exit 0
fi

while true; do
  printf '\n\033[1;36mYou:\033[0m '
  IFS= read -r input || break
  [[ -z "${input}" ]] && continue
  [[ "${input}" == "/quit" || "${input}" == "/exit" ]] && break
  [[ "${input}" == "/session" ]] && {
    echo "${session_dir}"
    continue
  }

  harness_save_user_message "${session_dir}" "${input}"
  printf '\033[1;33mAgent:\033[0m '
  harness_agent_loop "${session_dir}"
  echo
done
